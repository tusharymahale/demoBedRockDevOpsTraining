
 {
  "family": "bedrock-chatbot-task",
  "networkMode": "awsvpc",
  "executionRoleArn": "arn:aws:iam::348342705231:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "bedrock-chatbot",
      "image": "348342705231.dkr.ecr.eu-north-1.amazonaws.com/bedrock-chatbot:test",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/bedrock-chatbot-task",
          "awslogs-region": "eu-north-1",
	  "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ],
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024"
}
 
